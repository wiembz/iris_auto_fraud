data/raw/
data/interim/
data/processed/
data/external/
*.csv
*.xlsx
*.xls
*.parquet
*.pkl
*.joblib

# =========================
# Keep selected documentation reports if needed
# =========================
!data/quality_reports/
!data/quality_reports/**/
!data/quality_reports/**/*.md
!data/quality_reports/**/*.txt

# If you want to keep audit CSVs in Git, uncomment this:
# !data/quality_reports/**/*.csv

